---
import Layout from '../../layouts/Layout.astro';
import PostGame from '../../components/PostGame.astro';

// Reusing a hexagon shape for the 6-letter category
const hexagonPoints = '45,5 80,22 80,68 45,85 10,68 10,22';
---

<Layout title="6 Letters - The Word" variant="game">
	<main class="game-container">
    
		<section class="lobby-section" id="lobby">
			<div class="shape-container">
				<svg class="hexagon-shape" viewBox="0 0 90 90" xmlns="http://www.w3.org/2000/svg">
					<polygon points={hexagonPoints} />
				</svg>
			</div>

			<div class="insight-card">
				<ul class="insight-list">
					<li>Broader nouns & spatial terms.</li>
					<li>Compound and descriptive phrases.</li>
					<li>Nature and constructed environments.</li>
				</ul>
			</div>

		</section>

		<section class="board-section" id="game-board">
			<div class="grid-container">
				{/* Generates a 5x6 grid: 5 attempts (rows) by 6 letters (cols) */}
				{Array.from({ length: 30 }).map((_, i) => (
					<div class="tile" data-index={i}></div>
				))}
			</div>

			<div class="keyboard" id="virtual-keyboard">
				{["QWERTYUIOP", "ASDFGHJKL", "ZXCVBNM"].map((row, i) => (
					<div class="kb-row">
						{i === 2 && <button class="kb-key wide" data-key="Enter">ENTER</button>}
						{row.split("").map(char => (
							<button class="kb-key" data-key={char}>{char}</button>
						))}
						{i === 2 && <button class="kb-key wide" data-key="Backspace">⌫</button>}
					</div>
				))}
			</div>
		</section>
		<PostGame />
	</main>
</Layout>

<script>
	// Inform the client this page uses 6-letter words
	(window as any).WORD_LENGTH = 6;
	(window as any).MAX_ATTEMPTS = 5;
	(window as any).LANG = localStorage.getItem('theword-lang') || 'es';
</script>

<script type="module" src="/src/scripts/game-client.ts"></script>

<style>
	.scroll-trigger {
		background: transparent;
		border: none;
		cursor: pointer;
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: var(--space-sm);
		color: var(--color-accent); 
		padding: var(--space-md);
	}

	.arrow-icon {
		width: 48px;
		height: 48px;
		fill: none;
		stroke: var(--color-accent); 
		stroke-width: 2.5;
		stroke-linecap: round;
		stroke-linejoin: round;
		animation: bounce 2s infinite ease-in-out;
	}

	@keyframes bounce {
		0%, 20%, 50%, 80%, 100% { transform: translateY(0); }
		40% { transform: translateY(-12px); }
		60% { transform: translateY(-6px); }
	}
</style>

<style>
	.game-container {
		height: 100vh;
		overflow-y: auto;
		scroll-snap-type: y mandatory;
	}

	.lobby-section, .board-section {
		height: 100vh;
		display: flex;
		flex-direction: column;
		align-items: center;
		justify-content: center;
		scroll-snap-align: start;
		padding: var(--space-lg);
	}

	.hexagon-shape { width: 90px; height: 90px; }
	.hexagon-shape polygon { fill: var(--color-accent); }

	.insight-card {
		background: var(--color-card);
		padding: var(--space-lg);
		border-radius: var(--radius-card);
		margin: var(--space-xl) 0;
		width: 100%;
		max-width: 300px;
	}

	.insight-list { list-style: none; font-size: 0.85rem; color: var(--color-accent); }

	.grid-container {
		display: grid;
		grid-template-columns: repeat(6, 1fr); /* 6 columns for 6-letter words */
		gap: var(--space-sm);
		max-width: fit-content;
	}

	.tile {
		width: var(--tile-size);
		height: var(--tile-size);
		border: 2px solid var(--color-tile-border);
		border-radius: var(--radius-tile);
		background: rgba(255, 255, 255, 0.05);
		display: flex;
		align-items: center;
		justify-content: center;
		font-size: var(--tile-font-size);
		font-family: var(--font-body);
		font-weight: bold;
	}

	.kb-row { display: flex; gap: 4px; margin-bottom: 4px; }
	.kb-key {
		background: var(--color-btn);
		color: var(--color-accent);
		padding: 10px;
		border-radius: var(--radius-btn);
		min-width: 30px;
		font-size: 0.8rem;
	}
	.kb-key.wide { min-width: 60px; }
</style>
