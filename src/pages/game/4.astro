---
import Layout from '../../layouts/Layout.astro';
import PostGame from '../../components/PostGame.astro';

// Reusing the diamond shape from your index page [cite: 32]
const diamondPoints = '45,5 85,45 45,85 5,45';
---

<Layout title="4 Letters - The Word" variant="game">
  <main class="game-container">
    
    <section class="lobby-section" id="lobby">
      <div class="shape-container">
        <svg class="diamond-shape" viewBox="0 0 90 90" xmlns="http://www.w3.org/2000/svg">
          <polygon points={diamondPoints} />
        </svg>
      </div>

      <div class="insight-card">
        <ul class="insight-list">
          <li>Mostly Irregular Verbs.</li>
          <li>Concrete & Tangible Nouns.</li>
          <li>Sensory Adjectives.</li>
        </ul>
      </div>

    </section>

    <section class="board-section" id="game-board">
      <div class="grid-container">
        {/* Generates a 5x4 grid: 5 attempts (rows) by 4 letters (cols) */}
        {Array.from({ length: 20 }).map((_, i) => (
          <div class="tile" data-index={i}></div>
        ))}
      </div>

      <div class="keyboard" id="virtual-keyboard">
        {["QWERTYUIOP", "ASDFGHJKL", "ZXCVBNM"].map((row, i) => (
          <div class="kb-row">
            {i === 2 && <button class="kb-key wide" data-key="Enter">ENTER</button>}
            {row.split("").map(char => (
              <button class="kb-key" data-key={char}>{char}</button>
            ))}
            {i === 2 && <button class="kb-key wide" data-key="Backspace">⌫</button>}
          </div>
        ))}
      </div>
    </section>
    <PostGame />
  </main>
</Layout>

<script>
  // Wire page-level defaults for the client
  window.WORD_LENGTH = 4;
  window.MAX_ATTEMPTS = 5;
  window.LANG = localStorage.getItem('theword-lang') || 'es';
</script>
<script>
  import "../scripts/game-client.ts"; // Adjust the "../" depending on the file's location
</script>

<style>
  .scroll-trigger {
    background: transparent;
    border: none;
    cursor: pointer;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-sm);
    /* Set the text color here */
    color: var(--color-accent); 
    padding: var(--space-md);
  }

  .arrow-icon {
    width: 48px;
    height: 48px;
    /* 2. Explicitly set stroke properties here instead of in HTML */
    fill: none;
    stroke: var(--color-accent); 
    stroke-width: 2.5;
    stroke-linecap: round;
    stroke-linejoin: round;
    
    /* 3. Link the animation */
    animation: bounce 2s infinite ease-in-out;
  }

  /* 4. Ensure keyframes are inside the same <style> block */
  @keyframes bounce {
    0%, 20%, 50%, 80%, 100% { transform: translateY(0); }
    40% { transform: translateY(-12px); }
    60% { transform: translateY(-6px); }
  }
</style>

<style>
  .game-container {
    height: 100vh;
    overflow-y: auto;
    scroll-snap-type: y mandatory; /* Ensures the view "sticks" to the sections */
  }

  .lobby-section, .board-section {
    height: 100vh;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    scroll-snap-align: start;
    padding: var(--space-lg);
  }

  /* Lobby Specifics */
  .diamond-shape { width: 90px; height: 90px; }
  .diamond-shape polygon { fill: var(--color-accent); }

  .insight-card {
    background: var(--color-card);
    padding: var(--space-lg);
    border-radius: var(--radius-card);
    margin: var(--space-xl) 0;
    width: 100%;
    max-width: 300px;
  }

  .insight-list { list-style: none; font-size: 0.85rem; color: var(--color-accent); }

  /* Board Specifics */
  /* Update these in the <style> section of 4.astro */
.grid-container {
  display: grid;
  grid-template-columns: repeat(4, 1fr); /* 4 columns for 4-letter words */
  gap: var(--space-sm);
  max-width: fit-content;
}

.tile {
  width: var(--tile-size);
  height: var(--tile-size);
  border: 2px solid var(--color-tile-border); /* Transparent border from your tokens */
  border-radius: var(--radius-tile);
  background: rgba(255, 255, 255, 0.05); /* Slight fill to see them against the brown */
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: var(--tile-font-size);
  font-family: var(--font-body);
  font-weight: bold;
}
  /* Keyboard UI */
  .kb-row { display: flex; gap: 4px; margin-bottom: 4px; }
  .kb-key {
    background: var(--color-btn);
    color: var(--color-accent);
    padding: 10px;
    border-radius: var(--radius-btn);
    min-width: 30px;
    font-size: 0.8rem;
  }
  .kb-key.wide { min-width: 60px; }
</style>